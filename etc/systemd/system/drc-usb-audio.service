[Unit]
Description=Setup DRC audio routing when USB DAC is connected
After=sound.target
Wants=brutefir-drc.service
After=brutefir-drc.service

[Service]
Type=oneshot
User=giacomo
Environment=HOME=/home/giacomo
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=XDG_RUNTIME_DIR=/run/user/1001
ExecStartPre=/bin/sleep 1
ExecStart=/bin/bash -c 'mpc enable only 3; mpc --port 6601 enable only 3'

--- a/sys/dev/sound/usb/uaudio.c	2026-05-22 02:00:00.000000000 +0200
+++ b/sys/dev/sound/usb/uaudio.c	2026-06-06 14:49:58.259710000 +0200
@@ -1009,6 +1009,24 @@
 
 	/* fill channel info */
 	uaudio_chan_fill_info(sc, uaa->device);
+
+	/*
+	 * OKTO RESEARCH DAC8 STEREO (0x152a:0x88c5) exposes a single UAC2
+	 * Clock Source shared between its playback and capture interfaces.
+	 * The idle capture channel reprograms that shared clock to its
+	 * 48 kHz-family default and clobbers the active playback rate,
+	 * which breaks the entire 44.1 kHz family (continuous USB
+	 * stream-lock loss / front-panel flicker).  This host uses the
+	 * device for playback only, so drop the capture channels: that
+	 * removes the shared-clock contention and additionally lets uaudio
+	 * use the device's explicit asynchronous feedback endpoint.
+	 */
+	if (uaa->info.idVendor == 0x152a && uaa->info.idProduct == 0x88c5) {
+		for (i = 0; i != UAUDIO_MAX_CHILD; i++)
+			sc->sc_rec_chan[i].num_alt = 0;
+		device_printf(dev, "OKTO DAC8: capture interface disabled "
+		    "(shared-clock 44.1kHz workaround)\n");
+	}
 
 	DPRINTF("audio rev %d.%02x\n",
 	    sc->sc_audio_rev >> 8,

# Single source of host-specific values for the audio box.
#
# install.sh substitutes these into every *.in template (@VAR@ syntax, the same
# convention arki-ctrl uses) to generate the live config files.  To retarget the
# whole system to another user/box, edit this file and re-run ./install.sh —
# nothing else needs to change.
#
# REPO_DIR is auto-detected by install.sh (the directory it lives in); set it
# here only to override.

AUDIO_USER=giacomo
AUDIO_HOME=/home/giacomo
PREFIX=/usr/local

# Music library location (host-specific; the Linux mount path may differ from
# FreeBSD — e.g. /media/USBHD2/musica vs a Linux mountpoint).
MUSIC_DIR=/media/USBHD2/musica

# upmpdcli: Qobuz account username (the streaming password is NOT stored here —
# set qobuzpass locally if needed).  Leave blank to disable Qobuz.
QOBUZ_USER=delleceste@gmail.com

# UPnP/OpenHome renderer friendly name exposed on the network.
# Defaults to the machine hostname; override here for a custom label.
FRIENDLY_NAME=$(hostname)

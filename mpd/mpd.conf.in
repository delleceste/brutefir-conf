###################################
#
#  Linux-specific mpd.conf (uses ALSA)
#
#  DAC      : hw:0,0   — direct, bit-perfect playback (OKTO-DAC output)
#  Loopback : hw:1     — snd-aloop capture side feeds brutefir (DRC outputs)
#
#  Template — generated to mpd.conf by ../install.sh from ../config.env.
#  Do not edit the generated file; edit this .in or config.env.
#
#  Counterpart of mpd/musicpd.conf (FreeBSD / OSS).  The FreeBSD virtual_oss
#  loopback (/dev/dsp.play <-> /dev/dsp.loop) is replaced here by the ALSA
#  snd-aloop module (see etc/modules-load.d/snd-aloop.conf).  MPD writes to
#  hw:1,0 and brutefir captures from hw:1,1.
#

follow_inside_symlinks  "yes"
# State lives under the audio user's home (the run-from-repo model): /var is not
# writable by an unprivileged user.  Create with: mkdir -p ~/.local/share/mpd ~/.cache/mpd
db_file         "@AUDIO_HOME@/.local/share/mpd/mpd.db"
log_file        "@AUDIO_HOME@/.local/share/mpd/mpd.log"
pid_file        "@AUDIO_HOME@/.cache/mpd/pid"
music_directory         "@MUSIC_DIR@"
# playlist_directory      "@AUDIO_HOME@/.local/share/mpd/playlists"
state_file      "@AUDIO_HOME@/.local/share/mpd/mpdstate"
user    "@AUDIO_USER@"
bind_to_address         "0.0.0.0"
port    "6600"
log_level       "default"
volume_normalization    "no"
audio_buffer_size       "16384"
filesystem_charset      "UTF-8"
auto_update     "no"
mixer_type      "disabled"
group   "@AUDIO_USER@"
max_connections "20"
restore_paused "yes"

resampler {
  plugin "soxr"
  quality "very high"
}

# Output 1 — direct to DAC, no room correction.
# hw:0,0 addresses the raw hardware device: no dmix, no auto-resampling,
# bit-perfect.  Requires the DAC to be free (brutefir / DRC outputs stopped).
audio_output {
        type "alsa"
        name "OKTO-DAC"
        device "hw:0,0"
        mixer_type        "none"
}

# Native DRC output — brutefir loopback, no MPD format conversion.
#
# drc.sh <rate> restarts brutefir at the selected sample rate, then enables
# this output.  The selected rate must match the source track rate for native
# playback.
#
# MPD's "format" syntax is sample_rate:bits:channels.  An asterisk means that
# the attribute is not enforced.  Therefore "*:*:*" means:
#   * keep the source sample rate
#   * keep the source bit depth
#   * keep the source channel count
#
# This is intentional: setting "44100:24:2" or similar would force MPD to
# convert to that format.  For native DRC, 44.1 kHz / 16-bit and 44.1 kHz /
# 24-bit sources both use this same output; the bit depth is not the routing
# selector.
audio_output {
        type "alsa"
        name "DRC-native"
        device "hw:Loopback,0,0"
        format "*:*:*"
        enabled "no"
        mixer_type        "none"
}

# DRC-resamp: MPD resamples all source material to 192 kHz before sending to
# brutefir.  Useful for mixed-rate playlists.  Uses the soxr resampler plugin
# configured above.
audio_output {
        type "alsa"
        name "DRC-resamp"
        device "hw:Loopback,0,0"
        format "192000:24:2"
        enabled "no"
        mixer_type        "none"
}
